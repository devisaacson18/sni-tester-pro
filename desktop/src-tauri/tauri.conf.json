{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SNI Tester PRO",
  "version": "4.0.4",
  "identifier": "com.devisaacson.snitesterpro",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SNI Tester PRO",
        "width": 1024,
        "height": 700,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon.png"
    ]
  }
}
